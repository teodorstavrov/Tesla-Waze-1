# ── OpenChargeMap ──────────────────────────────────────────────────────────────
# Get a free key at: https://openchargemap.org/site/develop/api
OPENCHARGEMAP_API_KEY=

# ── TomTom (future — traffic overlay) ─────────────────────────────────────────
# TOMTOM_API_KEY=

# ── Vite client-side env (must be prefixed VITE_) ─────────────────────────────
# If you expose the OCM key to the frontend directly (not recommended for prod)
# VITE_OPENCHARGEMAP_API_KEY=

# ── API base URL ───────────────────────────────────────────────────────────────
# Leave empty for same-origin (Vercel / dev proxy). Set to full URL if hosting
# the API separately.
# VITE_API_BASE=
